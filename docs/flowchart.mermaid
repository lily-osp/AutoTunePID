flowchart TD
    Start([Start]) --> Init[Initialize AutoTunePID]
    Init --> Config[Configure Parameters]

    subgraph Configuration
        Config --> SetMethod[Set Tuning Method]
        Config --> SetSetpoint[Set Setpoint]
        Config --> SetFilters[Configure Filters]
        Config --> SetDuration[Set Tuning Duration]
    end

    SetMethod --> CheckMode{Check Mode}

    CheckMode -->|Manual| ManualPath[Manual Mode]
    ManualPath --> ReadGains[Read Manual Gains]
    ReadGains --> UpdatePID

    CheckMode -->|Auto| AutoPath[Auto-tuning Mode]

    subgraph AutoTuning
        AutoPath --> CheckState{Check Tuning State}

        CheckState -->|Initial| InitTuning[Initialize Tuning]
        InitTuning --> ResetVars[Reset Variables]
        ResetVars --> StartTuning[Start Tuning Process]

        CheckState -->|Oscillating| ProcessTuning[Process Tuning]
        ProcessTuning --> DetectPeaks[Detect Peaks]
        DetectPeaks --> CollectData[Collect Oscillation Data]
        CollectData --> CheckDuration{Check Duration}

        CheckDuration -->|Not Complete| Continue[Continue Tuning]
        Continue --> ProcessTuning

        CheckDuration -->|Complete| FinalizeTuning[Finalize Tuning]

        FinalizeTuning --> SelectMethod{Select Tuning Method}
        SelectMethod -->|Ziegler-Nichols| ZN[Calculate ZN Gains]
        SelectMethod -->|Cohen-Coon| CC[Calculate CC Gains]
        SelectMethod -->|Relay Feedback| RF[Calculate RF Gains]
        SelectMethod -->|IMC| IMC[Calculate IMC Gains]

        ZN & CC & RF & IMC --> SetGains[Set Final PID Gains]
    end

    SetGains --> UpdatePID[Update PID Controller]

    subgraph PIDComputation
        UpdatePID --> ReadInput[Read Input]
        ReadInput --> ApplyInputFilter{Input Filter Enabled?}

        ApplyInputFilter -->|Yes| FilterInput[Apply Input Filter]
        ApplyInputFilter -->|No| CalcError[Calculate Error]
        FilterInput --> CalcError

        CalcError --> UpdateTerms[Update PID Terms]
        UpdateTerms --> ComputeOutput[Compute Output]

        ComputeOutput --> ApplyOutputFilter{Output Filter Enabled?}
        ApplyOutputFilter -->|Yes| FilterOutput[Apply Output Filter]
        ApplyOutputFilter -->|No| LimitOutput[Limit Output]
        FilterOutput --> LimitOutput
    end

    LimitOutput --> OutputReady[Output Ready]
    OutputReady --> Loop{Continue?}

    Loop -->|Yes| CheckMode
    Loop -->|No| End([End])

    subgraph Monitoring
        direction TB
        OutputReady --> Monitor[Monitor Process]
        Monitor --> UpdateStats[Update Statistics]
        UpdateStats --> LogData[Log Data]
    end

    %% Styling
    classDef configNode fill:#e1f5fe,stroke:#01579b
    classDef tuningNode fill:#fff3e0,stroke:#e65100
    classDef pidNode fill:#e8f5e9,stroke:#1b5e20
    classDef monitorNode fill:#f3e5f5,stroke:#4a148c

    class Config,SetMethod,SetSetpoint,SetFilters,SetDuration configNode
    class AutoPath,ProcessTuning,DetectPeaks,CollectData,FinalizeTuning,SetGains tuningNode
    class UpdatePID,ReadInput,CalcError,UpdateTerms,ComputeOutput,LimitOutput pidNode
    class Monitor,UpdateStats,LogData monitorNode
